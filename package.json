{
  "name": "hyperspeed-canary-todos",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Canary project for HyperSpeed Track D end-to-end runner validation. Tiny TypeScript todo-list API used as a fixture target for run-canary.mjs.",
  "scripts": {
    "test": "vitest run",
    "test:integration": "vitest run tests/integration",
    "build": "tsc --noEmit",
    "start": "node --import tsx/esm src/server.ts",
    "dev": "node --watch --import tsx/esm src/server.ts"
  },
  "dependencies": {
    "pg": "^8.11.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
