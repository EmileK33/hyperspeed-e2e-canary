{
  "name": "app",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc -p tsconfig.server.json && vite build",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "migrate": "ts-node-dev --transpile-only src/db/migrate.ts",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600",
    "@influxdata/influxdb-client": "^1.33",
    "@sendgrid/mail": "^8.1",
    "@sentry/node": "^8.9",
    "@tanstack/react-query": "^5.48",
    "axios": "^1.7",
    "bcrypt": "^5.1",
    "bullmq": "^5.7",
    "cookie-parser": "^1.4",
    "cors": "^2.8",
    "express": "^4.19",
    "express-rate-limit": "^7.3",
    "helmet": "^7.1",
    "ioredis": "^5.4",
    "jsonwebtoken": "^9.0",
    "jspdf": "^2.5",
    "multer": "^1.4",
    "papaparse": "^5.4",
    "pg": "^8.12",
    "puppeteer": "^22.11",
    "react": "^18.3",
    "react-dom": "^18.3",
    "react-router-dom": "^6.24",
    "uuid": "^10.0",
    "zod": "^3.23",
    "zustand": "^4.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.45",
    "@testing-library/jest-dom": "^6.4",
    "@testing-library/react": "^16.0",
    "@testing-library/user-event": "^14.5",
    "@types/bcrypt": "^5.0",
    "@types/cookie-parser": "^1.4",
    "@types/cors": "^2.8",
    "@types/express": "^4.17",
    "@types/jsonwebtoken": "^9.0",
    "@types/multer": "^1.4",
    "@types/node": "^20.14",
    "@types/papaparse": "^5.3",
    "@types/pg": "^8.11",
    "@types/supertest": "^6.0",
    "@types/uuid": "^10.0",
    "@typescript-eslint/eslint-plugin": "^7.16",
    "@typescript-eslint/parser": "^7.16",
    "@vitejs/plugin-react": "^4.3",
    "autoprefixer": "^10.4",
    "dotenv": "^16.4",
    "eslint": "^8.57",
    "eslint-plugin-n": "^17",
    "postcss": "^8.4",
    "prettier": "^3.3",
    "supertest": "^7.0",
    "tailwindcss": "^3.4",
    "ts-node-dev": "^2.0",
    "typescript": "^5.5",
    "vite": "^5.3",
    "vitest": "^2.0"
  }
}
